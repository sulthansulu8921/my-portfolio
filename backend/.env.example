# Django
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=your-backend-domain.onrender.com

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# CORS - point to your frontend domain
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# AWS / Supabase Storage (for project images in production)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=portfolio-media
AWS_S3_ENDPOINT_URL=https://xxxx.storage.supabase.co/storage/v1/s3

# Google Gemini AI (for the AI chat feature)
GEMINI_API_KEY=your-gemini-api-key
